# ─── AI API Gateway — environment template ─────────────────────────────────────
#
# Environment-specific files are used by docker.sh:
#
#   .env.dev      → ./docker.sh dev      (or just ./docker.sh)
#   .env.local    → ./docker.sh local    (Ollama only, no cloud keys)
#   .env.staging  → ./docker.sh staging
#   .env.prod     → ./docker.sh prod
#
# To get started, copy whichever file suits your use case and fill in real values:
#   cp .env.dev .env.dev        # already exists — just add your API keys
#   cp .env.example .env.prod   # for a fresh prod config
#
# The legacy .env file (used by plain `docker compose up`) is still supported.

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys. Leave empty to disable auth (dev only).
GATEWAY_API_KEYS=your-secret-key-here

# ─── LLM Provider Credentials ─────────────────────────────────────────────────
# Leave blank to disable a provider; the gateway skips it during routing.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Sidecar Service URLs ──────────────────────────────────────────────────────
# Defaults work with docker-compose. Override only when running outside compose.
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# Local Ollama (compose service or external instance)
OLLAMA_BASE_URL=http://ollama:11434

# ─── Security Pipeline ────────────────────────────────────────────────────────
# false = sidecar timeout lets the request through (dev-friendly)
# true  = sidecar timeout blocks the request (production)
SIDECAR_FAIL_CLOSED=false

# block = HTTP 400 on injection detection | flag = warning header only
PIPELINE_INJECTION_MODE=block

# redact = strip PII before/after LLM | flag = header warning | off = disabled
PIPELINE_PII_MODE=redact

# Requests with aggregate risk score >= this are blocked (range: 0–100)
RISK_SCORE_BLOCK_THRESHOLD=75

POLICY_FILE=config/policies.yaml

# true = include risk score and reasons in error responses (disable in prod)
VERBOSE_ERRORS=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100
RATE_LIMIT_TPM=0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Empty = deny all cross-origin requests.
CORS_ALLOWED_ORIGINS=

# ─── Request size ─────────────────────────────────────────────────────────────
MAX_REQUEST_BODY_BYTES=1048576

# ─── Environment & streaming ───────────────────────────────────────────────────
# Set to "production" to enable startup safety checks (see GATEWAY_ENV docs).
# The gateway refuses to start in production mode with unsafe config values.
GATEWAY_ENV=development

# buffered  — buffer the full stream, run output PII scan, then re-emit.
#             Safe but adds latency equal to total generation time (default).
# passthrough — true streaming, output PII scan is skipped. Faster but PII
#             in LLM responses will not be redacted.
PIPELINE_STREAM_MODE=buffered

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
