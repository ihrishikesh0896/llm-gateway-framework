# ─── Locally-hosted LLM via external Ollama (bare metal / separate host) ──────
# Use this when Ollama is NOT running inside the docker-compose stack —
# e.g. Ollama installed natively on the host, a dedicated GPU server,
# or a remote LAN machine.
#
# Install Ollama on the host:
#   curl -fsSL https://ollama.com/install.sh | sh
#
# By default Ollama listens on 127.0.0.1:11434.
# To expose it on all interfaces (needed when gateway runs in Docker):
#   OLLAMA_HOST=0.0.0.0 ollama serve
#
# If Ollama is on a separate machine on the LAN:
#   OLLAMA_BASE_URL=http://192.168.1.50:11434
#
# Then, in docker-compose.yml, remove the ollama service entirely and
# point OLLAMA_BASE_URL at the host. For Docker Desktop (Mac/Windows),
# "host.docker.internal" resolves to the host machine:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
GATEWAY_API_KEYS=local-dev-key

# ─── Providers ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Point at the host machine from inside Docker (Mac / Windows Docker Desktop)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# For Linux Docker where host.docker.internal is not available:
# OLLAMA_BASE_URL=http://172.17.0.1:11434

# For a dedicated GPU server on the LAN:
# OLLAMA_BASE_URL=http://192.168.1.50:11434

# ─── Sidecar URLs (docker-compose defaults) ────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
SIDECAR_FAIL_CLOSED=false
PIPELINE_INJECTION_MODE=block
PIPELINE_PII_MODE=redact
RISK_SCORE_BLOCK_THRESHOLD=75
POLICY_FILE=config/policies.yaml

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=20
RATE_LIMIT_TPM=0

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
