# ─── Anthropic-only configuration ─────────────────────────────────────────────
# Copy to .env, fill in real values, then run: docker compose up
#
# Routed models (auto-detected by prefix):
#   claude-opus-4-7
#   claude-sonnet-4-6
#   claude-haiku-4-5-20251001
#   claude-3-5-sonnet-20241022
#   claude-3-5-haiku-20241022
#   claude-3-opus-20240229
#
# Note: Anthropic requires max_tokens in every request.
#       The gateway defaults to 4096 if omitted.

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
GATEWAY_API_KEYS=your-gateway-key-here

# ─── Providers ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# ─── Sidecar URLs (docker-compose defaults) ────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
PIPELINE_INJECTION_MODE=block
PIPELINE_PII_MODE=redact
RISK_SCORE_BLOCK_THRESHOLD=75
POLICY_FILE=config/policies.yaml

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100
RATE_LIMIT_TPM=0

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
