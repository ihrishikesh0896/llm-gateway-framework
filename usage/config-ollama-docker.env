# ─── Locally-hosted LLM via Ollama (Docker Compose) ───────────────────────────
# Zero cloud dependency — all inference stays on your machine.
# Copy to .env, then run: docker compose up
#
# Pull models AFTER the stack is up:
#   docker exec ai-api-gateway-ollama-1 ollama pull llama3.2
#   docker exec ai-api-gateway-ollama-1 ollama pull mistral
#   docker exec ai-api-gateway-ollama-1 ollama pull codellama
#   docker exec ai-api-gateway-ollama-1 ollama pull phi3
#   docker exec ai-api-gateway-ollama-1 ollama pull gemma2
#
# All requests go to Ollama regardless of model name prefix because no cloud
# keys are set. Set "provider": "ollama" in requests to be explicit.
#
# GPU acceleration (NVIDIA):
#   Add to the ollama service in docker-compose.yml:
#     deploy:
#       resources:
#         reservations:
#           devices:
#             - driver: nvidia
#               count: 1
#               capabilities: [gpu]

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
GATEWAY_API_KEYS=local-dev-key

# ─── Providers — no cloud keys ─────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# ─── Sidecar URLs (docker-compose defaults) ────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
# Fail-open for sidecars: if Presidio/Gitleaks are slow to start, don't block.
SIDECAR_FAIL_CLOSED=false
PIPELINE_INJECTION_MODE=block
PIPELINE_PII_MODE=redact
RISK_SCORE_BLOCK_THRESHOLD=75
POLICY_FILE=config/policies.yaml

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Local models are slower — lower RPM to avoid queue buildup
RATE_LIMIT_RPM=20
RATE_LIMIT_TPM=0

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
