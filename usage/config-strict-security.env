# ─── Strict security / production configuration ────────────────────────────────
# Hardened settings for production or regulated environments.
# Every security control is enabled; sidecars run fail-closed.
#
# Key differences from defaults:
#   - SIDECAR_FAIL_CLOSED=true   → sidecar timeout blocks the request
#   - PIPELINE_PII_MODE=redact   → PII stripped from both input and output
#   - RISK_SCORE_BLOCK_THRESHOLD=50 → block at medium risk, not just high
#   - VERBOSE_ERRORS=false        → never expose risk scores to callers
#   - CORS locked to known origins

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
# Use long random keys; rotate regularly
GATEWAY_API_KEYS=prod-key-64-chars-random-here,svc-account-key-here

# ─── Providers ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# ─── Sidecar URLs ──────────────────────────────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
# Fail-closed: if sidecars are unreachable, block the request
SIDECAR_FAIL_CLOSED=true

# Block on prompt injection (not just flag)
PIPELINE_INJECTION_MODE=block

# Redact PII in both input (before LLM) and output (after LLM)
PIPELINE_PII_MODE=redact

# Block at medium risk (50) rather than the default high (75)
RISK_SCORE_BLOCK_THRESHOLD=50

POLICY_FILE=config/policies.yaml

# Never leak risk scores, reasons, or internal labels to API callers
VERBOSE_ERRORS=false

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Tighter limits in production to limit blast radius
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=100000

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Restrict cross-origin access to your app domain only
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# ─── Request size ──────────────────────────────────────────────────────────────
# Reduce max body to 256 KB to limit prompt-stuffing attacks
MAX_REQUEST_BODY_BYTES=262144

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=warning
