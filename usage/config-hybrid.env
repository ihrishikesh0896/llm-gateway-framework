# ─── Hybrid configuration (SaaS primary + local Ollama fallback) ───────────────
# Cloud models handle routine traffic; Ollama absorbs overflow and acts as
# a last-resort fallback when cloud providers are unavailable.
#
# Routing logic:
#   gpt-4o-mini   → OpenAI (primary)
#                     └─ claude-haiku-4-5-20251001 (Anthropic fallback)
#                           └─ llama3.2 (local Ollama last resort)
#
# Edit config/fallbacks.yaml to extend the chains, e.g.:
#   fallbacks:
#     gpt-4o-mini:
#       - claude-haiku-4-5-20251001
#       - llama3.2
#
# To force local inference for a specific request, set "provider": "ollama"
# in the request body regardless of which model name you pass.

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
GATEWAY_API_KEYS=your-gateway-key-here

# ─── Providers ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
# Ollama runs as a sidecar in the same compose stack
OLLAMA_BASE_URL=http://ollama:11434

# ─── Sidecar URLs (docker-compose defaults) ────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
# Fail-open so a slow sidecar startup doesn't block inference
SIDECAR_FAIL_CLOSED=false
PIPELINE_INJECTION_MODE=block
PIPELINE_PII_MODE=redact
RISK_SCORE_BLOCK_THRESHOLD=75
POLICY_FILE=config/policies.yaml

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100
RATE_LIMIT_TPM=0

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
