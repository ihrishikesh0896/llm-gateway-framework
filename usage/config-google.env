# ─── Google Gemini-only configuration ─────────────────────────────────────────
# Copy to .env, fill in real values, then run: docker compose up
#
# Routed models (auto-detected by "gemini-" prefix):
#   gemini-2.0-flash-exp
#   gemini-1.5-pro
#   gemini-1.5-flash
#   gemini-1.5-flash-8b
#
# Get your API key at: https://aistudio.google.com/app/apikey

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
GATEWAY_API_KEYS=your-gateway-key-here

# ─── Providers ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=AIza...
OLLAMA_BASE_URL=http://ollama:11434

# ─── Sidecar URLs (docker-compose defaults) ────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
PIPELINE_INJECTION_MODE=block
PIPELINE_PII_MODE=redact
RISK_SCORE_BLOCK_THRESHOLD=75
POLICY_FILE=config/policies.yaml

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100
RATE_LIMIT_TPM=0

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
