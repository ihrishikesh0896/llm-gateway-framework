# ─── Multi-cloud configuration (OpenAI + Anthropic + Google) ──────────────────
# Copy to .env, fill in real values, then run: docker compose up
#
# The gateway auto-routes by model name prefix:
#   gpt-*, o1-*, o3-*  → OpenAI
#   claude-*            → Anthropic
#   gemini-*            → Google
#
# If the primary provider fails, fallback chains (config/fallbacks.yaml) kick in
# and retry with the next model. Example:
#   gpt-4o fails → tries claude-sonnet-4-6 → tries gemini-1.5-pro
#
# You can also pin a provider per-request with: "provider": "anthropic"

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
# Multiple keys — each gets its own rate-limit bucket and policy
GATEWAY_API_KEYS=prod-key-abc123,readonly-key-xyz789

# ─── Providers ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
OLLAMA_BASE_URL=http://ollama:11434

# ─── Sidecar URLs (docker-compose defaults) ────────────────────────────────────
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
GITLEAKS_SIDECAR_URL=http://gitleaks-sidecar:8080

# ─── Security Pipeline ─────────────────────────────────────────────────────────
PIPELINE_INJECTION_MODE=block
PIPELINE_PII_MODE=redact
RISK_SCORE_BLOCK_THRESHOLD=75
POLICY_FILE=config/policies.yaml

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# 200 RPM per key across all providers combined
RATE_LIMIT_RPM=200
# 500k tokens per minute per key (0 = unlimited)
RATE_LIMIT_TPM=500000

# ─── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
